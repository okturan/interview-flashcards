{
  "name": "interview-flashcards",
  "version": "1.0.0",
  "description": "Bilingual Java interview flashcards with spaced repetition, offline storage, and progress tracking.",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "check:deploy-tool": "wrangler --version",
    "deploy": "vite build && wrangler pages deploy dist --project-name java-flashcards"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "dexie": "^4.2.1",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.545.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.10",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.2.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "vite": "^7.1.9",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.43.0"
  }
}
